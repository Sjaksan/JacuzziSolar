# Kopieer dit bestand naar:
# /etc/jacuzzi-solar/jacuzzi-solar.env

# Web server
WEB_PORT=3000

# HomeWizard P1
P1_IP=192.168.1.171

# Heater sensor (SCT-013 + ADS1115)
# Zet op 1 om in te schakelen, 0 om uit te laten.
HEATER_SENSOR_ENABLED=0

# Drempel wanneer heater als AAN wordt gezien.
HEATER_CURRENT_THRESHOLD_A=1.0

# Netspanning voor vermogensschatting.
LINE_VOLTAGE_V=230

# ADS1115 instellingen
ADS1115_I2C_BUS=1
ADS1115_ADDRESS=72
ADS1115_CHANNEL=0

# SCT-013 calibratie (mV per A)
SCT_MV_PER_AMP=10
